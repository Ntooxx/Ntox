{
  "name": "ntox",
  "version": "0.1.0",
  "description": "Cognitive CLI agent with persistent memory, multi-channel gateway, and Docker sandboxing",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ntox": "dist/index.js"
  },
  "files": [
    "dist/",
    "skills/",
    "web/",
    "LICENSE",
    "README.md",
    "install.sh",
    "install.ps1"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "setup": "tsx src/index.ts setup",
    "gateway": "tsx src/index.ts gateway",
    "gateway:build": "node dist/index.js gateway",
    "gateway:discord": "tsx src/index.ts gateway discord",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build",
    "prepare": "husky"
  },
  "keywords": [
    "ai",
    "agent",
    "cli",
    "cognitive",
    "llm",
    "personal-assistant",
    "pattern-compilation",
    "telegram",
    "discord",
    "docker",
    "sandbox"
  ],
  "author": "Anton Pupkov",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ntooxx/Ntox"
  },
  "bugs": {
    "url": "https://github.com/Ntooxx/Ntox/issues"
  },
  "homepage": "https://github.com/Ntooxx/Ntox#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "conf": "^13.1.0",
    "confbox": "^0.2.2",
    "express": "^5.2.1",
    "gpt-tokenizer": "^3.4.0",
    "ora": "^8.1.1",
    "socket.io": "^4.8.3",
    "ws": "^8.21.1",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^22.14.1",
    "@types/ws": "^8.18.1",
    "eslint": "^10.7.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.65.0",
    "vitest": "^4.1.10"
  }
}
